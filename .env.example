# Database - use PostgreSQL on Railway
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Admin credentials (set on first deploy, then change in app)
# These are used to seed the initial admin account
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Optional: Site URL for production
NEXT_PUBLIC_SITE_URL="https://your-railway-app.up.railway.app"